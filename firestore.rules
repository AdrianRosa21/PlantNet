rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla de Oro: El usuario es dueño de todo lo que esté bajo su /users/{userId}
    // Esto cubre crops, notes, chatMessages, irrigationLogs, etc.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Forzamos actualización de reglas para el Chat IA
    match /users/{userId}/crops/{cropId}/chatMessages/{messageId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
