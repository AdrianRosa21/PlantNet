rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict user-ownership model designed for a crop management application. 
     * Security is grounded in a hierarchical data structure where all user-related data is nested 
     * directly under the user's primary profile document.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      match /crops/{cropId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        match /notes/{noteId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.cropId == cropId;
          allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId && request.resource.data.cropId == resource.data.cropId;
          allow delete: if isExistingOwner(userId);
        }

        match /recommendations/{recommendationId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.cropId == cropId;
          allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId && request.resource.data.cropId == resource.data.cropId;
          allow delete: if isExistingOwner(userId);
        }

        match /chatMessages/{chatMessageId} {
          allow get, list: if isOwner(userId);
          // Explicit check for ownership and relational integrity
          allow create: if isOwner(userId) 
            && request.resource.data.userId == userId 
            && request.resource.data.cropId == cropId;
          allow update: if isExistingOwner(userId) 
            && request.resource.data.userId == resource.data.userId 
            && request.resource.data.cropId == resource.data.cropId;
          allow delete: if isExistingOwner(userId);
        }

        match /irrigationLogs/{irrigationLogId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.cropId == cropId;
          allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId && request.resource.data.cropId == resource.data.cropId;
          allow delete: if isExistingOwner(userId);
        }
      }
    }
  }
}