rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regla maestra: El usuario tiene acceso total a cualquier dato dentro de su propia ruta /users/{userId}
    // Esto incluye crops, notes, chatMessages, etc. de forma automática y segura.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Forzamos despliegue con este comentario para asegurar sincronización de reglas.
  }
}
