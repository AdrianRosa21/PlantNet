rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGLA MAESTRA: El usuario autenticado tiene acceso total a SU carpeta
    // Esto cubre crops, notes, chatMessages e id de usuario
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Regla de respaldo para el nodo de usuario
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
